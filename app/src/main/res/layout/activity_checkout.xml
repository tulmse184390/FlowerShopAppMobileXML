<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checkout Details"
        android:textColor="#333333"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvAddressLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Shipping Address *"
        android:textColor="#5A5A5A"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/edtAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_rounded_gray"
        android:hint="Enter your full address..."
        android:minLines="3"
        android:gravity="top|start"
        android:padding="12dp"
        android:textColor="#333333"
        app:layout_constraintTop_toBottomOf="@id/tvAddressLabel" />

    <TextView
        android:id="@+id/tvPaymentLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Payment Method"
        android:textColor="#5A5A5A"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/edtAddress"
        app:layout_constraintStart_toStartOf="parent" />

    <RadioGroup
        android:id="@+id/rgPaymentMethod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:checkedButton="@+id/rbVnPay"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentLabel">

        <RadioButton
            android:id="@+id/rbVnPay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VNPAY Gateway"
            android:buttonTint="@color/pink_primary"
            android:paddingStart="8dp" />

        <RadioButton
            android:id="@+id/rbCOD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cash on Delivery (COD)"
            android:buttonTint="@color/pink_primary"
            android:paddingStart="8dp" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlaceOrder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Proceed to Payment"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:backgroundTint="@color/pink_primary"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>